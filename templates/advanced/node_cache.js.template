const NodeCache = require('node-cache');

const cache = new NodeCache();

const setCache = (key, value, ttl) => ttl ? cache.set(key, value, ttl) : cache.set(key, value);
const getCache = (key) => cache.get(key);
const deleteCache = (key) => cache.del(key);
const clearCache = () => cache.flushAll();
const hasCache = (key) => cache.has(key);

module.exports = { setCache, getCache, deleteCache, clearCache, hasCache };
